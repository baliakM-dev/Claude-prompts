# Permission / security guardrail návrh

{
  "permissions": {
    "allowedCommands": [
      "git",
      "mvn",
      "./mvnw",
      "gradle",
      "./gradlew",
      "npm",
      "node",
      "docker",
      "docker-compose",
      "docker compose",
      "psql",
      "grep",
      "find",
      "sed",
      "awk",
      "cat",
      "ls"
    ],
    "blockedCommands": [
      "rm",
      "sudo",
      "chmod 777",
      "curl | sh",
      "wget | sh"
    ],
    "allowedDirectories": [
      "./src",
      "./frontend",
      "./docs",
      "./docker",
      "./migrations",
      "./config",
      "./scripts",
      "./tests"
    ],
    "blockedDirectories": [
      "./.git",
      "./node_modules",
      "./target",
      "./build",
      "./.env",
      "./secrets",
      "./certs"
    ],
    "requireConfirmation": [
      "git push",
      "docker push",
      "npm publish",
      "./mvnw release:*",
      "./gradlew publish"
    ]
  }
}

# File protection hook nápad

{
  "hooks": {
    "PreToolUse": [{
      "matcher": "Edit|Write",
      "hooks": [{
        "type": "command",
        "command": "if [[ \"$CLAUDE_FILE_PATHS\" == *\".env\"* ]] || [[ \"$CLAUDE_FILE_PATHS\" == *\"application-prod.yml\"* ]] || [[ \"$CLAUDE_FILE_PATHS\" == *\"secrets\"* ]]; then echo 'Protected file: modification blocked'; exit 2; fi"
      }]
    }]
  }
}

CLAUDE.md drží stály projektový kontext,
AGENTS.md drží špecializované role,
.claude/commands/ drží opakované workflow,
permissions + hooks držia guardraily.

